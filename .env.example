# ANCAP Core API
# Copy to .env and adjust

# Database (sync URL for Alembic: use postgresql:// without +asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ancap

# Auth
SECRET_KEY=your-long-random-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cron job protection (optional, recommended for production)
# If set, POST /v1/system/jobs/tick requires X-Cron-Secret header to match this value
# Generate with: openssl rand -hex 32  or  python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# Optional
DEBUG=false

# ----------------------------
# L3: Chain anchors (mock | acp | ethereum | solana)
# ----------------------------
# Driver selection for POST /v1/chain/anchor
CHAIN_ANCHOR_DRIVER=mock

# ACP node JSON-RPC endpoint (must support method: ancap_anchor)
ACP_RPC_URL=http://127.0.0.1:8545/rpc

# Ethereum/Solana RPC endpoints must also support custom method ancap_anchor
# (regular public RPC endpoints will NOT have this method unless you run a shim/gateway)
ETHEREUM_RPC_URL=
SOLANA_RPC_URL=
