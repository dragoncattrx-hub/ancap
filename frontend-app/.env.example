##
# ANCAP Frontend
# Copy to .env.local (dev) or set env in your deployment.
##

# If set, the frontend will use this as API base.
# Recommended values:
# - dev (local API via Docker port):   NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/v1
# - dev (default; use Next rewrite):   (unset) -> /api/v1
# - prod-like behind reverse proxy:    NEXT_PUBLIC_API_URL=/api/v1
# - production ancap.cloud:            NEXT_PUBLIC_API_URL=https://ancap.cloud/api/v1
NEXT_PUBLIC_API_URL=

