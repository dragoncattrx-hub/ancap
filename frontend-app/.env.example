##
# ANCAP Frontend
# Copy to .env.local (dev) or set env in your deployment.
##

# If set, the frontend will use this as API base.
# Recommended values:
# - dev (local API via Docker port):   NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/v1
# - dev (default; use Next rewrite):   (unset) -> /api/v1
# - prod-like behind reverse proxy:    NEXT_PUBLIC_API_URL=/api/v1
# - production ancap.cloud:            NEXT_PUBLIC_API_URL=/api/v1 (Docker nginx) or https://ancap.cloud/api/v1
# Optional separate API host (requires Cloudflare Tunnel hostname): https://api.ancap.cloud/v1
NEXT_PUBLIC_API_URL=

# ACP landing: default is same-origin /acp (leave unset).
# - external microsite only: NEXT_PUBLIC_ACP_URL=https://example.com
NEXT_PUBLIC_ACP_URL=

